# ─── Copy this file to .env and fill in your values ────────────────────────────
PORT=8080

# MongoDB Atlas connection string (change to your Atlas URI)
DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Stripe keys (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# The public URL of this server (used in email links)
# For EC2: http://<EC2-PUBLIC-IP>:8080  OR  https://<your-domain.com>
FRONTEND_URL=http://<EC2-PUBLIC-IP>:8080

# Email (Nodemailer) — use Gmail App Password or SES SMTP credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
