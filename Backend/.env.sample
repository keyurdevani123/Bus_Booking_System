# ─── Copy this file to .env and fill in your values ────────────────────────────
PORT=8080

# MongoDB Atlas connection string (change to your Atlas URI)
DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Stripe keys (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Frontend app URL (used for Stripe success/cancel redirects and email links)
# Example (Vercel): https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Comma-separated CORS allowlist
# Include local dev + deployed frontend URL(s)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Email (Nodemailer) — use Gmail App Password or SES SMTP credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
# Optional: force all outgoing mail to one inbox for testing
MAIL_OVERRIDE_TO=
RESEND_API_KEY=re_xxx
# Optional for Resend:
# - by default the app uses the safe sender `BusBazaar <onboarding@resend.dev>`
# - only set RESEND_USE_CONFIGURED_FROM=true after verifying your custom domain in Resend
RESEND_FROM_EMAIL=BusBazaar <onboarding@resend.dev>
RESEND_USE_CONFIGURED_FROM=false
