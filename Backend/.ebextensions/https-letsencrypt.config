commands:
  00_install_certbot:
    command: "pip3 install certbot certbot-nginx --quiet --disable-pip-version-check || true"
    ignoreErrors: true

container_commands:
  01_obtain_cert:
    command: "certbot --nginx -d keyurdevani.me -d www.keyurdevani.me --non-interactive --agree-tos --email devanikeyur19@gmail.com --redirect || true"
    ignoreErrors: true
  02_auto_renew:
    command: "(crontab -l 2>/dev/null | grep -v certbot; echo '0 3 * * * /usr/local/bin/certbot renew --quiet --nginx') | crontab -"
    ignoreErrors: true
