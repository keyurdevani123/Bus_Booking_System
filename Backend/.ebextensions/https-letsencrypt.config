commands:
  00_install_certbot:
    command: "dnf install -y certbot python3-certbot-nginx || true"
    ignoreErrors: true

container_commands:
  01_obtain_cert:
    command: "certbot --nginx -d keyurdevani.me -d www.keyurdevani.me --non-interactive --agree-tos --email devanikeyur19@gmail.com --redirect || true"
    ignoreErrors: true
  02_auto_renew:
    command: "(crontab -l 2>/dev/null | grep -v certbot; echo '0 3 * * * certbot renew --quiet --nginx') | crontab -"
    ignoreErrors: true
