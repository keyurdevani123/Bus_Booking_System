# Backend environment sample - copy to .env.local and fill values
PORT=3200
DATABASE_URI=mongodb://localhost:27017/eticket
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=re_xxx
# Optional:
# - leave unset to use the safe default `BusBazaar <onboarding@resend.dev>`
# - or set a sender from your verified custom domain
RESEND_FROM_EMAIL=BusBazaar <onboarding@resend.dev>
